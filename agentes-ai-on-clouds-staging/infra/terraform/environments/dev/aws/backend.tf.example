# Copiar a backend.tf y completar antes de terraform init en equipo/CI.

terraform {
  backend "s3" {
    bucket         = "REPLACE-tfstate-bucket"
    key            = "agentes-ai/dev/aws/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "REPLACE-tf-lock"
  }
}
